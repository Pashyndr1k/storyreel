{
  "name": "storyreel",
  "productName": "StoryReel",
  "version": "1.14.1",
  "private": true,
  "description": "AI assistant for writing short videos: from plot idea to per-shot image & video generation prompts.",
  "author": "StoryReel",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "app": "npm run build && electron .",
    "dist:win": "npm run build && electron-builder --win",
    "dist:mac": "npm run build && electron-builder --mac"
  },
  "dependencies": {
    "ffmpeg-static": "^5.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^37.0.0",
    "electron-builder": "^26.0.0",
    "vite": "^6.0.0"
  },
  "build": {
    "appId": "com.storyreel.app",
    "productName": "StoryReel",
    "publish": [
      {
        "provider": "github",
        "owner": "Pashyndr1k",
        "repo": "storyreel"
      }
    ],
    "files": [
      "dist/**",
      "electron/**"
    ],
    "asarUnpack": [
      "**/node_modules/ffmpeg-static/**"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": "universal"
        }
      ],
      "category": "public.app-category.video",
      "minimumSystemVersion": "11.0",
      "extendInfo": {
        "NSMicrophoneUsageDescription": "StoryReel uses the microphone to transcribe your spoken plot ideas and script edits."
      }
    }
  }
}
